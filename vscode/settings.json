{
    "editor.inlineSuggest.enabled": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "none",
    "editor.semanticHighlighting.enabled": true,
    "editor.fontSize": 12,
	"editor.fontFamily": "Inter, MesloLGS NF, Menlo, Monaco, 'Courier New', monospace",
    "editor.formatOnSave": false,
    "editor.snippetSuggestions": "top",
    "editor.suggestSelection": "recentlyUsed",
    "editor.suggest.showWords": false,
    "editor.suggest.showKeywords": false,

    "workbench.panel.defaultLocation": "right",
    "workbench.colorTheme": "Monokai Pro (Filter Machine)",
    "workbench.iconTheme": "Monokai Pro (Filter Machine) Icons",
    "markdown-preview-enhanced.previewMode": "Multiple Previews",
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 9,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.revealIfOpen": true,
    "workbench.editor.enablePreview": true,
    "workbench.editor.openSideBySideDirection":"right",

    "python.formatting.provider": "none",
    "ruff.importStrategy": "fromEnvironment",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSaveMode": "file",
        "editor.formatOnPaste": false
    },

    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 3,
    "markdown-preview-enhanced.previewTheme": "atom-dark.css",
    "markdown-preview-enhanced.codeBlockTheme": "xonokai.css",
    "markdown.preview.openMarkdownLinks": "inEditor",
	"files.associations": {
        ".env.*": "properties"
    },
	"files.exclude": {
        "**/.git": false,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/__pycache__": true
    },
    "logFileHighlighter.customPatterns": [
        {
            "pattern": "^Conversation Log of .*?$",
            "foreground": "#A6E22E",
            "fontStyle": "bold"
        },
        {
            "pattern": "^-{50,}\\s*$",
            "foreground": "#888888"
        },
        {
            "pattern": "^\\[USER\\]",
            "foreground": "#50FA7B",
            "fontStyle": "bold"
        },
        {
            "pattern": "^\\[ASSISTANT\\]",
            "foreground": "#FF5555",
            "fontStyle": "bold"
        },
    ],
    "editor.inlayHints.enabled": "off",
    "chatgpt.commentCodeLensEnabled": false,
    "cursor.chat.enableCoAuthoredByTrailer": false,
    "diffviewer.colorScheme": "dark",
    "claudeCode.initialPermissionMode": "bypassPermissions",
    "claudeCode.allowDangerouslySkipPermissions": true,
    "claudeCode.respectGitIgnore": false,
    "claudeCode.enableNewConversationShortcut": true,
    "claudeCode.hideOnboarding": true,
    "claudeCode.useTerminal": false,
    "claudeCode.autosave": true,
    "git-graph.maxDepthOfRepoSearch": 1,
    "git-graph.repository.fetchAndPrune": true,
    "terminal.integrated.focusAfterRun": "none",

    "git.openDiffOnClick": true,
    "gitlens.codeLens.enabled": false,
    "gitlens.statusBar.enabled": false,
    "gitlens.blame.heatmap.enabled": false,
    "gitlens.graph.defaultItemLimit": 150,
    "gitlens.graph.pageItemLimit": 100,
    "gitlens.graph.minimap.enabled": false,
    "gitlens.graph.scrollMarkers.enabled": false,
    "gitlens.graph.pullRequests.enabled": false,
    "gitlens.graph.issues.enabled": false,
    "gitlens.graph.avatars": true,
    "gitlens.graph.statusBar.enabled": false,
    "gitlens.graph.dimMergeCommits": true,
    "gitlens.graph.highlightRowsOnRefHover": true,
    "gitlens.graph.showGhostRefsOnRowHover": false,
    "workbench.colorCustomizations": {
        "gitlens.graphLane1Color": "#3b9eff",
        "gitlens.graphLane2Color": "#ff5fb0",
        "gitlens.graphLane3Color": "#5ccb5f",
        "gitlens.graphLane4Color": "#ffab2e",
        "gitlens.graphLane5Color": "#b07cff",
        "gitlens.graphLane6Color": "#ff6b6b",
        "gitlens.graphLane7Color": "#36d6e7",
        "gitlens.graphLane8Color": "#d4e157",
        "gitlens.graphLane9Color": "#ff8a5c",
        "gitlens.graphLane10Color": "#7c8cff"
    }
}
